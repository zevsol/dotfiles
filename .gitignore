# ==============================================================================
# 0. Git 自身与系统底层隔离 (防止扫描底层和回收站)
# ==============================================================================
/.dotfiles-bare/
/$RECYCLE.BIN/
/System Volume Information/

# ==============================================================================
# 1. Scoop 环境隔离 (由 Scoop 自身管理，绝不提交)
# ==============================================================================
/Scoop/

# ==============================================================================
# 2. VS Code 数据精简 (保留配置，剔除缓存与海量插件)
# ==============================================================================
/Data/
/Data/VSCode/Extensions/
/Data/VSCode/AppData/Cache/
/Data/VSCode/AppData/CachedData/
/Data/VSCode/AppData/CachedExtensionVSIX/
/Data/VSCode/AppData/Crashpad/
/Data/VSCode/AppData/logs/
/Data/VSCode/AppData/User/WorkspaceStorage/
/Data/VSCode/AppData/User/globalStorage/

# ==============================================================================
# 3. 敏感信息与安全防护 (密钥、证书、本地环境变量)
# ==============================================================================
# 绝对不要提交的私钥与凭证
**/.ssh/id_rsa
**/.ssh/id_ed25519
**/.ssh/*.key
**/.ssh/*.pem
**/*.key
**/*.pem
**/*.pfx
**/*.cer
**/ssh/

# 业务开发环境变量本地文件
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.local
**/*.user

# ==============================================================================
# 4. 开发语言通用垃圾依赖 (防止 node_modules 等百万碎片文件拖垮 Git)
# ==============================================================================
**/node_modules/
**/bower_components/
**/jspm_packages/

# Python 虚拟环境与缓存
**/venv/
**/.venv/
**/env/
**/.env/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.poetry/

# Rust / Go / Java 编译产物
**/target/
**/bin/
**/obj/
**/out/
**/dist/
**/build/

# ==============================================================================
# 5. 全局临时文件与系统噪音
# ==============================================================================
**/Cache/
**/cache/
**/Temp/
**/temp/
**/Logs/
**/logs/
**/*.tmp
**/*.log
**/*.backup
**/*.old
**/*.bak
**/*.swp
*~
# ==============================================================================
# 6. 全局AI 配置文件
# ==============================================================================
# === Claude Code ===
# 拦截授权 Token
**/claude/.claude.json
# 拦截记忆与缓存历史
**/claude/.claude/agent-memory/
**/claude/.claude/cache/
**/claude/.claude/history.jsonl

# 操作系统特有噪音
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store